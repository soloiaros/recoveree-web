# Use the bare project URL ONLY — do NOT include /rest/v1/ or any other path.
# You can find this on Supabase dashboard -> Project Settings -> API -> "Project URL".
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# The anon/publishable key from Supabase dashboard -> Project Settings -> API.
# Both legacy JWT anon keys (eyJ...) and the new sb_publishable_... keys work.
VITE_SUPABASE_ANON_KEY=your-anon-public-key
